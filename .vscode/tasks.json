{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "backend: dev server",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"cd backend && source ../.venv/bin/activate && uvicorn app.main:app --reload --port 8000"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "frontend: dev server",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"cd frontend && npm run dev"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		}
	]
}